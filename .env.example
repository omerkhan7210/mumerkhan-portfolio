# Example Environment Variables
# Copy this file to .env.local and fill in your values

# Your domain (used for SEO and OG tags)
NEXT_PUBLIC_SITE_URL=https://mumerkhan.com

# Supabase Supavisor connection pooler — IPv4-compatible (server-side
# only, used by app/api/contact/route.ts to store contact form
# submissions). Use the "Transaction mode" pooler string from
# Project Settings → Database → Connection Pooling, NOT the direct
# db.<ref>.supabase.co host — that one is IPv6-only and will fail to
# resolve on most VPS/local networks.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres

# Google Tag Manager container ID
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# SMTP — used by app/api/contact/route.ts to send the lead
# notification (to SALES_EMAIL) and the personalized auto-reply
# (to the form submitter). Get these from your email provider
# (e.g. Hostinger email hosting, Google Workspace, etc.)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=sales@mumerkhan.com
SMTP_PASS=your_mailbox_password
SALES_EMAIL=sales@mumerkhan.com

# Google Search Console API — base64-encoded service account JSON key
# (see lib/searchConsole.ts + scripts/submit-sitemap.js). The service
# account email must be added as a user on the Search Console
# property with "Full" permission before this will work.
# Generate the base64 value with:
#   base64 -w0 path/to/service-account-key.json   (Linux/Mac/Git Bash)
#   certutil -encode path\to\key.json tmp.b64      (Windows, then strip header/footer lines)
GOOGLE_SERVICE_ACCOUNT_KEY=

# Optional: Formspree Form ID (for contact form)
# NEXT_PUBLIC_FORMSPREE_ID=your_formspree_id

# Optional: Google Analytics
# NEXT_PUBLIC_GA_ID=your_google_analytics_id
