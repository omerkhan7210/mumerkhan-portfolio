# Example Environment Variables
# Copy this file to .env.local and fill in your values

# Your domain (used for SEO and OG tags)
NEXT_PUBLIC_SITE_URL=https://mumerkhan.com

# Supabase Supavisor connection pooler — IPv4-compatible (server-side
# only, used by app/api/contact/route.ts to store contact form
# submissions). Use the "Transaction mode" pooler string from
# Project Settings → Database → Connection Pooling, NOT the direct
# db.<ref>.supabase.co host — that one is IPv6-only and will fail to
# resolve on most VPS/local networks.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres

# Google Tag Manager container ID
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Optional: Formspree Form ID (for contact form)
# NEXT_PUBLIC_FORMSPREE_ID=your_formspree_id

# Optional: Google Analytics
# NEXT_PUBLIC_GA_ID=your_google_analytics_id
